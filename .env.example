# Runtime mode
WALLET_MODE=mock
WDK_MODULE=wdk

# Wallet addresses (for mock/demo)
TREASURY_WALLET_ADDRESS=0xTreasuryWallet
CHECKING_WALLET_ADDRESS=0xCheckingWallet
DEFAULT_USDT_TOKEN=USDt

# Core mandate parameters
MIN_LIQUID_USDT=500
PR_PAYOUT_USDT=50
VOLATILITY_HEDGE_PERCENT=0.1

# Autonomous loop
EVALUATION_INTERVAL_SECONDS=600
ENABLE_HEDGE=true

# Chains and fees
ALLOWED_CHAINS=arbitrum,base
BRIDGE_FEE_USDT=3

# GitHub integration
GITHUB_REPO_OWNER=your-org
GITHUB_REPO_NAME=your-repo
GITHUB_TOKEN=

# APIs (optional in mock mode)
APY_API_URL=https://yields.llama.fi/pools
GAS_API_URL=
