# Runtime mode
WALLET_MODE=wdk
WDK_MODULE=wdk-http
DEFAULT_CHAIN=polygon
WDK_SERVICE_URL=http://127.0.0.1:8787
WDK_SERVICE_TIMEOUT_SECONDS=20
ACTIVITY_LOG_PATH=data/activity_log.jsonl

# Wallet addresses (for mock/demo)
TREASURY_WALLET_ADDRESS=0x107119102c2EC84099cDce3D5eFDE2dcbf4DEB2a
CHECKING_WALLET_ADDRESS=0x107119102c2EC84099cDce3D5eFDE2dcbf4DEB2a
DEFAULT_USDT_TOKEN=USDT

# Core mandate parameters
MIN_LIQUID_USDT=500
PR_PAYOUT_USDT=50
VOLATILITY_HEDGE_PERCENT=0

# Autonomous loop
EVALUATION_INTERVAL_SECONDS=600
ENABLE_HEDGE=false
ENABLE_YIELD_MOVES=false

# Chains and fees
ALLOWED_CHAINS=bnb,polygon
BRIDGE_FEE_USDT=3

# GitHub integration
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_TOKEN=
CONTRIBUTOR_WALLETS_PATH=data/contributor_wallets.json

# APIs (optional in mock mode)
APY_API_URL=https://yields.llama.fi/pools
GAS_API_URL=

# WDK integration artifacts
TOKEN_MAP_PATH=config/token_map.json
PROTOCOL_MAP_PATH=config/protocol_map.json
